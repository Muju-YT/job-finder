# Django Configuration
SECRET_KEY=django-insecure-mock-key-for-development-only-change-this-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Default to SQLite, change for PostgreSQL)
DATABASE_URL=sqlite:///db.sqlite3
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Redis & Channel Layer Configuration (Set up for Django Channels)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS Allowed Origins (Comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
